 "html": "<style>\n\n@page {\n    size: A4;\n    margin: 1cm;\n}\n\n.urgent {\n    color: white;\n    background: red;\n    font-weight: bold;\n    padding: 6px;\n    text-align:center;\n}\n\n.amount {\n    font-size: 28px;\n    font-weight: bold;\n}\n\n.page-break {\n    page-break-before: always;\n}\n\ntable {\n    border-collapse: collapse;\n}\n\ntable th, table td {\n    padding: 6px;\n}\n\n@media print {\n    button, .btn {\n        display: none;\n    }\n}\n\n</style>\n{%- from \"templates/print_formats/standard_macros.html\" import add_header -%}\n\n<!-- HEADER -->\n<div id=\"header-html\" class=\"hidden-pdf\">\n    {{ add_header(0,1,doc,letter_head, no_letterhead) }}\n</div>\n\n\n<h2>\n{{ get_shop_name() }}\n</h2>\n\n<hr>\n\n<h3>{{ _(\"Job Card Receipt\") }}</h3>\n\n<p>\n<b>{{ _(\"Customer\") }}</b> : {{ doc.customer_name }}\n</p>\n\n<p>\n<b>{{ _(\"Device\") }}</b> : {{ doc.device_brand }} {{ doc.device_model }}\n</p>\n\n\n{% if doc.priority == \"Urgent\" %}\n<div class=\"urgent\">\n{{ _(\"URGENT\") }}\n</div>\n{% endif %}\n\n<hr>\n\n<h4>{{ _(\"Parts Used\") }}</h4>\n\n<table border=\"1\" width=\"100%\">\n\n<tr>\n<th>{{ _(\"Part\") }}</th>\n<th>{{ _(\"Qty\") }}</th>\n<th>{{ _(\"Price\") }}</th>\n</tr>\n\n\n{% if doc.parts_used %}\n\n{% for p in doc.parts_used %}\n\n<tr>\n<td>{{ p.part }}</td>\n<td>{{ p.quantity }}</td>\n<td>{{ frappe.utils.fmt_money(p.total_price) }}</td>\n</tr>\n\n{% endfor %}\n\n{% endif %}\n\n</table>\n\n\n{% if doc.parts_used and (doc.parts_used|length) > 10 %}\n<div class=\"page-break\"></div>\n{% endif %}\n\n\n<br>\n\n\n<div class=\"amount\">\n{{ frappe.utils.fmt_money(doc.final_amount) }}\n</div>\n\n\n<br>\n\n\n\n<p>{{ doc.print_summary }}</p>\n<div style=\"text-align:center\">\n<img src=\"https://api.qrserver.com/v1/create-qr-code/?size=120x120&data={{ frappe.utils.get_url_to_form('Job Card', doc.name) }}\" width=\"120\" height=\"120\">\n</div>\n\n\n<!-- FOOTER -->\n<div id=\"footer-html\" class=\"visible-pdf\">\n\n{% if not no_letterhead and footer %}\n\n<div class=\"letter-head-footer\">\n{{ footer }}\n</div>\n\n{% endif %}\n\n</div>",
